{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✓ Agent task completed - check output quality'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash hooks/session-end.sh"
      }
    ],
    "TeammateIdle": [
      {
        "type": "command",
        "command": "bash hooks/teammate-idle.sh"
      }
    ]
  }
}
